{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "country_code",
    "party_id",
    "id",
    "publish",
    "address",
    "city",
    "postal_code",
    "country",
    "coordinates",
    "evses",
    "last_updated"
  ],
  "properties": {
    "country_code": { "type": "string", "minLength": 2, "maxLength": 2 },
    "party_id": { "type": "string", "minLength": 3, "maxLength": 3 },
    "id": { "type": "string", "maxLength": 39 },
    "publish": { "type": "boolean" },
    "evses": {
      "type": "array",
      "minItems": 1,
      "items": {
          "type": "object",
          "required": ["uid", "status", "connectors"],
          "properties": {
              "uid": { "type": "string" },
               "status": {
                  "type": "string",
                  "enum": ["AVAILABLE", "BLOCKED", "CHARGING", "INOPERATIVE", "OUT_OFORDER", "PLANNED", "REMOVED", "RESERVED", "UNKNOWN"]
               }
          }
      }
    }
  }
}
