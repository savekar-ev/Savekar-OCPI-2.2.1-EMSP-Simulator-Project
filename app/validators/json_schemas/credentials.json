{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "token",
    "url",
    "roles"
  ],
  "properties": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "business_details",
          "party_id",
          "country_code"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "CPO",
              "EMSP",
              "HUB",
              "NAP",
              "SCSP"
            ]
          },
          "business_details": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "party_id": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "country_code": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2
          }
        }
      }
    }
  }
}
